---
permalink: /search-index.json
---
[
  {%- for item in collections.searchable -%}
  {
    "title": {{ item.data.title | dump | safe }},
    "url": {{ item.url | dump | safe }},
    "content": {{ item.templateContent | striptags | replace("\n", " ") | replace("\r", " ") | replace("\t", " ") | dump | safe }}
  }{% if not loop.last %},{% endif %}
  {%- endfor -%}
]
